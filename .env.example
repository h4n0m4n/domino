# Domino — Cascading Impact Engine
# Copy this file to .env and fill in your values

# ──── Required: None! Domino works out of the box with free APIs ────

# ──── Optional: Enhanced data sources ────

# Oil Price API (free tier: 10K requests)
# Get yours at: https://www.oilpriceapi.com/
OILPRICE_API_KEY=

# FRED (Federal Reserve Economic Data)
# Get yours at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ──── Optional: AI Model ────

# Default: Ollama (local, free). No config needed if Ollama is running.
# Override with cloud provider if needed:
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# Alternative: OpenAI-compatible API
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=

# Alternative: Google AI Studio (free tier)
# LLM_PROVIDER=google
# GOOGLE_API_KEY=

# ──── Server ────
HOST=0.0.0.0
PORT=8000
